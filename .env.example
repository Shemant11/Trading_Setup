# trader — environment file
# Copy to .env and fill in. Secrets should live in ~/.trader/secrets.enc (managed by install.py).

TRADER_ENV=dev                       # dev | paper | live
TRADER_HOME=~/.trader
TRADER_LOG_LEVEL=INFO
TRADER_LOG_JSON=true

# API bind (dashboard). Default is localhost-only.
TRADER_API_HOST=127.0.0.1
TRADER_API_PORT=8000

# Database
TRADER_DB_URL=sqlite+aiosqlite:///~/.trader/trader.db
# For Postgres upgrade path:
# TRADER_DB_URL=postgresql+asyncpg://trader:trader@localhost:5432/trader

# Redis
TRADER_REDIS_URL=redis://localhost:6379/0

# Config file
TRADER_CONFIG=~/.trader/config.yaml

# Secrets passphrase (for decrypting ~/.trader/secrets.enc).
# Leave empty and the app will prompt on startup.
TRADER_SECRETS_PASSPHRASE=

# Global kill switch (also honored: file ~/.trader/halt.lock, Redis key trader:halt)
TRADER_HALT=0
